# Server-side weather API keys for local `.env.local` or Netlify
# Add only the providers you actually use. Do not expose them with NEXT_PUBLIC.

METEOCAT_API_KEY=

# --- Supabase (REQUERIT per guardar dades de calibratge) ---
# Obteniu aquests valors a https://supabase.com/dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional però recomanat per a operacions del servidor (bypass RLS):
SUPABASE_SERVICE_ROLE_KEY=